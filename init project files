# =========================
# 生成图片
# =========================
canvas = create_canvas(template_style)
canvas = add_background_decorations(canvas, template_style)
draw = ImageDraw.Draw(canvas)

main_center_x = canvas.size[0] // 2

# 主图默认居中
if main_uploaded is not None:
    main_img = Image.open(main_uploaded).convert("RGBA")
    main_img = main_img.resize((main_width, main_height))

    main_img = crop_to_shape(
        main_img,
        shape=main_shape,
        corner_radius=corner_radius,
        add_border=add_border,
        border_width=border_width,
        border_color=(255, 255, 255, 255)
    )

    main_x = (canvas.size[0] - main_img.size[0]) // 2
    main_y = (canvas.size[1] - main_img.size[1]) // 2

    canvas.paste(main_img, (main_x, main_y), main_img)

    # 上方文字：相对主图顶部居中
    top_font = load_font(top_font_size)
    draw_center_text(
        draw,
        top_text,
        main_x + main_img.size[0] // 2,
        main_y + top_text_y_offset,
        top_font,
        top_text_color
    )

    # 下方文字：相对主图底部居中
    bottom_font = load_font(bottom_font_size)
    draw_center_text(
        draw,
        bottom_text,
        main_x + main_img.size[0] // 2,
        main_y + main_img.size[1] + bottom_text_y_offset,
        bottom_font,
        bottom_text_color
    )

else:
    # 没有主图时文字按页面居中
    top_font = load_font(top_font_size)
    bottom_font = load_font(bottom_font_size)
    draw_center_text(draw, top_text, main_center_x, 180, top_font, top_text_color)
    draw_center_text(draw, bottom_text, main_center_x, 1120, bottom_font, bottom_text_color)

# 头像
