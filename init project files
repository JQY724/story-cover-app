def load_font(size=40):
    try:
        return ImageFont.truetype(FONT_PATH, size=size)
    except:
        return ImageFont.load_default()

def create_canvas(template_style="甜粉"):
    if template_style == "甜粉":
        bg = Image.new("RGBA", (1080, 1350), (255, 228, 239, 255))
    elif template_style == "奶油白粉":
        bg = Image.new("RGBA", (1080, 1350), (255, 246, 249, 255))
    elif template_style == "ins灰粉":
        bg = Image.new("RGBA", (1080, 1350), (241, 231, 235, 255))
    else:
        bg = Image.new("RGBA", (1080, 1350), (255, 228, 239, 255))
    return bg

def add_background_decorations(canvas, template_style="甜粉"):
    draw = ImageDraw.Draw(canvas)

    circles = [
        (55, 55, 125, 125, (255, 182, 193, 160)),
        (930, 90, 1015, 175, (255, 195, 210, 160)),
        (80, 1180, 160, 1260, (255, 210, 222, 160)),
        (920, 1140, 1010, 1230, (255, 168, 196, 150)),
    ]
    for x1, y1, x2, y2, color in circles:
        draw.ellipse((x1, y1, x2, y2), fill=color)

    for p in [(170, 120), (860, 220), (970, 1080), (140, 980), (540, 90)]:
        x, y = p
        draw.ellipse((x, y, x+12, y+12), fill=(255, 255, 255, 170))

    return canvas

def get_text_size(draw, text, font):
    bbox = draw.textbbox((0, 0), text, font=font)
    return bbox[2] - bbox[0], bbox[3] - bbox[1]

def draw_center_text(draw, text, center_x, y, font, fill):
    if not text.strip():
        return
    tw, th = get_text_size(draw, text, font)
    x = center_x - tw // 2
    draw.text((x, y), text, font=font, fill=fill)

def crop_to_shape(img, shape="矩形", corner_radius=40, add_border=False, border_width=12, border_color=(255,255,255,255)):
    img = img.convert("RGBA")
    w, h = img.size

    if shape == "矩形":
        result = img.copy()
    else:
        mask = Image.new("L", (w, h), 0)
        draw = ImageDraw.Draw(mask)

        if shape == "圆角矩形":
            draw.rounded_rectangle((0, 0, w, h), radius=corner_radius, fill=255)

        elif shape == "圆形":
            size = min(w, h)
            square = img.crop(((w-size)//2, (h-size)//2, (w+size)//2, (h+size)//2))
            img = square
            w, h = img.size
            mask = Image.new("L", (w, h), 0)
            draw = ImageDraw.Draw(mask)
            draw.ellipse((0, 0, w, h), fill=255)

        elif shape == "椭圆":
            draw.ellipse((0, 0, w, h), fill=255)

        elif shape == "爱心":
            points = []
            for t in range(360):
                tt = t * pi / 180
                x = 16 * sin(tt) ** 3
                y = 13 * cos(tt) - 5 * cos(2 * tt) - 2 * cos(3 * tt) - cos(4 * tt)
                px = w / 2 + x * w / 40
                py = h / 2 - y * h / 40
                points.append((px, py))
            draw.polygon(points, fill=255)

        elif shape == "拍立得":
            draw.rounded_rectangle((0, 0, w, h), radius=corner_radius, fill=255)

        elif shape == "胶片":
            draw.rounded_rectangle((0, 0, w, h), radius=corner_radius, fill=255)

        else:
            draw.rectangle((0, 0, w, h), fill=255)

        result = Image.new("RGBA", (w, h), (0, 0, 0, 0))
        result.paste(img, (0, 0), mask)

    if shape == "拍立得":
        pad_left = 20
        pad_top = 20
        pad_right = 20
        pad_bottom = 90
        framed = Image.new(
            "RGBA",
            (result.size[0] + pad_left + pad_right, result.size[1] + pad_top + pad_bottom),
            (255,255,255,255)
        )
        framed.paste(result, (pad_left, pad_top), result)
        result = framed

    if shape == "胶片":
        framed = Image.new("RGBA", (result.size[0] + 30, result.size[1] + 30), (35,35,35,255))
        framed.paste(result, (15, 15), result)
        draw2 = ImageDraw.Draw(framed)
        hole_w = 10
        hole_h = 18
        gap = 22
        for y in range(18, framed.size[1]-18, gap):
            draw2.rounded_rectangle((4, y, 4+hole_w, y+hole_h), radius=2, fill=(230,230,230,255))
            draw2.rounded_rectangle((framed.size[0]-14, y, framed.size[0]-4, y+hole_h), radius=2, fill=(230,230,230,255))
        result = framed

    if add_border and shape not in ["拍立得", "胶片"]:
        bordered = Image.new(
            "RGBA",
            (result.size[0] + border_width*2, result.size[1] + border_width*2),
            (0,0,0,0)
        )
        border_layer = Image.new("RGBA", bordered.size, border_color)
        bordered.paste(border_layer, (0, 0))
        bordered.paste(result, (border_width, border_width), result)
        result = bordered

    return result

def crop_avatar_circle(img, size):
    img = img.convert("RGBA").resize((size, size))
    mask = Image.new("L", (size, size), 0)
    draw = ImageDraw.Draw(mask)
    draw.ellipse((0, 0, size, size), fill=255)
    result = Image.new("RGBA", (size, size), (0, 0, 0, 0))
    result.paste(img, (0, 0), mask)
    return result

